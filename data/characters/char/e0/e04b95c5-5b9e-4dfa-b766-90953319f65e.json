ai.com/characters/eaa5eac0-73fa-4e3d-8c6b-d50dad3db9ef_character-illumina-venomshank-sibling-user-pov\" target=\"_blank\">Illumina</a></p><p><a rel=\"noopener noreferrer\" href=\"https://janitorai.com/characters/e488c7ad-ea3c-4163-b9cc-3b8ac24d9849_character-darkheart-venomshank-sibling-user-pov\" target=\"_blank\">Darkheart</a><","personality":"","scenario":"","first_message":"","avatar":"__GatteMXOYlFkWWFIkuG.webp","creator":"KirMirp","creator_verified":false,"nsfw":true,"tags":["👨 Male","🎮 Game","👤 AnyPOV"],"chats":106,"messages":611,"created_at":"2025-12-19T08:50:06.909988+00:00"}