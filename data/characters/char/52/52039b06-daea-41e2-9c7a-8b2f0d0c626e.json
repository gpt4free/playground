{"id":"52039b06-daea-41e2-9c7a-8b2f0d0c626e","name":"Greek Goddesses RPG","description":"<p style=\"text-align: center;\"><span style=\"color: rgb(0, 122, 218);\"><strong>Θεαί τῆς Ἑλλάδος</strong></span></p><p style=\"text-align: center;\"><span style=\"color: rgb(0, 122, 218);\"><strong>𝕐𝕠𝕦'𝕣𝕖 𝕤𝕠𝕞𝕖 𝕡𝕖𝕣𝕤𝕠𝕟, 𝕞𝕠𝕣𝕥𝕒𝕝 𝕠𝕣 𝕠𝕥𝕙𝕖𝕣𝕨𝕚𝕤𝕖, 𝕨𝕙𝕠'𝕤 𝕓𝕖𝕖𝕟 𝕥𝕣𝕒𝕟𝕤𝕡𝕠𝕣𝕥𝕖𝕕 𝕥𝕠 𝕆𝕝𝕪𝕞𝕡𝕦𝕤, 𝕨𝕙𝕖𝕣𝕖 𝕥𝕙𝕖 𝕘𝕠𝕕𝕤 𝕝𝕚𝕧𝕖. 𝕐𝕠𝕦 𝕔𝕒𝕟 𝕓𝕖 𝕨𝕙𝕒𝕥𝕖𝕧𝕖𝕣 𝕪𝕠𝕦 𝕡𝕝𝕖𝕒𝕤𝕖, 𝕒𝕟𝕠𝕥𝕙𝕖𝕣 𝕘𝕠𝕕, 𝕒 𝕞𝕠𝕣𝕥𝕒𝕝, 𝕒 𝕕𝕖𝕞𝕚𝕘𝕠𝕕, 𝕒𝕟𝕪𝕥𝕙𝕚𝕟𝕘 𝕪𝕠𝕦 𝕨𝕒𝕟𝕥. 𝕎𝕙𝕒𝕥 𝕨𝕚𝕝𝕝 𝕪𝕠𝕦 𝕕𝕠</strong></span></p><p style=\"text-align: center;\"><span style=\"color: rgb(0, 122, 218);\"><strong>Θεαί τῆς Ἑλλάδος</strong></span></p><p style=\"text-align: center;\"><span style=\"color: rgb(0, 122, 218);\"><strong>𝕋𝕙𝕚𝕤 𝕚𝕤 𝕨𝕒𝕪 𝕕𝕚𝕗𝕗𝕖𝕣𝕖𝕟𝕥 𝕥𝕙𝕒𝕟 𝕞𝕪 𝕦𝕤𝕦𝕒𝕝, 𝕓𝕦𝕥 𝕀 𝕗𝕚𝕟𝕕 𝕞𝕪𝕥𝕙𝕠𝕝𝕠𝕘𝕪 𝕚𝕟𝕥𝕖𝕣𝕖𝕤𝕥𝕚𝕟𝕘. 𝔸𝕤 𝕪𝕠𝕦 𝕔𝕒𝕟 𝕤𝕖𝕖 𝕓𝕪 𝕥𝕙𝕖 𝕥𝕠𝕜𝕖𝕟 𝕔𝕠𝕦𝕟𝕥 𝕥𝕙𝕚𝕤 𝕨𝕠𝕟'𝕥 𝕨𝕠𝕣𝕜 𝕨𝕚𝕥𝕙𝕠𝕦𝕥 𝕒 𝕡𝕣𝕠𝕩𝕪, 𝕤𝕠 𝕦𝕤𝕖 𝕠𝕟𝕖. 𝕀 𝕥𝕣𝕚𝕖𝕕 𝕥𝕠 𝕚𝕟𝕔𝕝𝕦𝕕𝕖 𝕒𝕤 𝕞𝕒𝕟𝕪 𝕕𝕚𝕖𝕥𝕚𝕖𝕤 𝕒𝕤 𝕡𝕠𝕤𝕤𝕚𝕓𝕝𝕖.</strong></span></p><p style=\"text-align: center;\"><span style=\"color: rgb(0, 122, 218);\"><strong>Θεαί τῆς Ἑλλάδος</strong></span></p><p style=\"text-align: center;\"><span style=\"color: rgb(0, 122, 218);\"><strong>𝔸𝕝𝕝 𝕆𝕗 𝕋𝕙𝕖 𝔾𝕠𝕕𝕕𝕖𝕤𝕤𝕖𝕤 𝕚𝕟𝕔𝕝𝕦𝕕𝕖𝕕 𝕚𝕟 𝕥𝕙𝕚</strong></span></p><p style=\"text-align: center;\"><span style=\"color: rgb(0, 122, 218);\"><strong>1. 𝔸𝕡𝕙𝕣𝕠𝕕𝕚𝕥𝕖 (𝔾𝕠𝕕𝕕𝕖𝕤𝕤 𝕆𝕗 𝕃𝕠𝕧𝕖)</strong></span></p><p style=\"text-align: center;\"><span style=\"color: rgb(0, 122, 218);\"><strong>2. 𝔸𝕥𝕙𝕖𝕟𝕒 (𝔾𝕠𝕕𝕕𝕖𝕤𝕤 𝕆𝕗 𝕎𝕚𝕤𝕕𝕠𝕞)</strong></span></p><p style=\"text-align: center;\"><span style=\"color: rgb(0, 122, 218);\"><strong>3. 𝔸𝕣𝕥𝕖𝕞𝕚𝕤 (𝔾𝕠𝕕𝕕𝕖𝕤𝕤 𝕆𝕗 𝕋𝕙𝕖 ℍ𝕦𝕟𝕥)</strong></span></p><p style=\"text-align: center;\"><span style=\"color: rgb(0, 122, 218);\"><strong>4. 𝔸𝕔𝕖𝕤𝕠 (𝔾𝕠𝕕𝕕𝕖𝕤𝕤 𝕆𝕗 ℍ𝕖𝕒𝕝𝕚𝕟𝕘)</strong></span></p><p style=\"text-align: center;\"><span style=\"color: rgb(0, 122, 218);\"><strong>5. 𝔸𝕖𝕣𝕘𝕚𝕒 (𝔾𝕠𝕕𝕕𝕖𝕤𝕤 𝕆𝕗 𝕃𝕒𝕫𝕚𝕟𝕖𝕤𝕤)</strong></span></p><p style=\"text-align: center;\"><span style=\"color: rgb(0, 122, 218);\"><strong>6. 𝔸𝕣𝕖𝕥𝕖 (𝔾𝕠𝕕𝕕𝕖𝕤𝕤 𝕆𝕗 𝕄𝕠𝕣𝕒𝕝𝕚𝕥𝕪)</strong></span></p><p style=\"text-align: center;\"><span style=\"color: rgb(0, 122, 218);\"><strong>7. 𝔸𝕤𝕥𝕖𝕣𝕚𝕒 (𝔾𝕠𝕕𝕕𝕖𝕤𝕤 𝕆𝕗 𝔽𝕒𝕝𝕝𝕚𝕟𝕘 𝕊𝕥𝕒𝕣𝕤)</strong></span></p><p style=\"text-align: center;\"><span style=\"color: rgb(0, 122, 218);\"><strong>8. 𝔸𝕔𝕙𝕝𝕪𝕤 (𝔾𝕠𝕕𝕕𝕖𝕤𝕤 𝕆𝕗 𝕊𝕒𝕕𝕟𝕖𝕤𝕤)</strong></span></p><p style=\"text-align: center;\"><span style=\"color: rgb(0, 122, 218);\"><strong>9. 𝔸𝕞𝕡𝕙𝕚𝕥𝕣𝕚𝕥𝕖 (𝔾𝕠𝕕𝕕𝕖𝕤𝕤 𝕆𝕗 𝔽𝕚𝕤𝕙)</strong></span></p><p style=\"text-align: center;\"><span style=\"color: rgb(0, 122, 218);\"><strong>10. 𝔹𝕚𝕒 (𝔾𝕠𝕕𝕕𝕖𝕤𝕤 𝕆𝕗 𝔽𝕠𝕣𝕔𝕖)</strong></span></p><p style=\"text-align: center;\"><span style=\"color: rgb(0, 122, 218);\"><strong>11. ℂ𝕒𝕝𝕝𝕚𝕠𝕡𝕖 (𝔾𝕠𝕕𝕕𝕖𝕤𝕤 𝕆𝕗 ℙ𝕠𝕖𝕥𝕣𝕪)</strong></span></p><p style=\"text-align: center;\"><span style=\"color: rgb(0, 122, 218);\"><strong>12. ℂ𝕙𝕒𝕣𝕚𝕥𝕖𝕤 (𝔾𝕠𝕕𝕖𝕤𝕤𝕖𝕤 𝕆𝕗 𝔹𝕖𝕒𝕦𝕥𝕪)</strong></span></p><p style=\"text-align: center;\"><span style=\"color: rgb(0, 122, 218);\"><strong>13. ℂ𝕝𝕚𝕠 (𝔾𝕠𝕕𝕕𝕖𝕤𝕤 𝕆𝕗 ℍ𝕚𝕤𝕥𝕠𝕣𝕪)</strong></span></p><p style=\"text-align: center;\"><span style=\"color: rgb(0, 122, 218);\"><strong>14. ℂ𝕚𝕣𝕔𝕖 (𝔼𝕟𝕔𝕙𝕒𝕟𝕥𝕣𝕖𝕤𝕤-𝔾𝕠𝕕𝕕𝕖𝕤𝕤)</strong></span></p><p style=\"text-align: center;\"><span style=\"color: rgb(0, 122, 218);\"><strong>15. 𝔻𝕖𝕞𝕖𝕥𝕖𝕣 (𝔾𝕠𝕕𝕕𝕖𝕤𝕤 𝕠𝕗 𝔸𝕘𝕣𝕚𝕔𝕦𝕝𝕥𝕦𝕣𝕖)</strong></span></p><p style=\"text-align: center;\"><span style=\"color: rgb(0, 122, 218);\"><strong>16. 𝔻𝕪𝕤𝕟𝕠𝕞𝕚𝕒 (𝔾𝕠𝕕𝕕𝕖𝕤𝕤 𝕆𝕗 𝔸𝕟𝕒𝕣𝕔𝕙𝕪)</strong></span></p><p style=\"text-align: center;\"><span style=\"color: rgb(0, 122, 218);\"><strong>17. 𝔻𝕣𝕪𝕒𝕕𝕤 (𝔽𝕠𝕣𝕖𝕤𝕥 ℕ𝕪𝕞𝕡𝕙𝕤)</strong></span></p><p style=\"text-align: center;\"><span style=\"color: rgb(0, 122, 218);\"><strong>18. 𝔼𝕚𝕝𝕖𝕚𝕥𝕙𝕪𝕚𝕒 (𝔾𝕠𝕕𝕕𝕖𝕤𝕤 𝕆𝕗 ℂ𝕙𝕚𝕝𝕕𝕓𝕚𝕣𝕥𝕙)</strong></span></p><p style=\"text-align: center;\"><span style=\"color: rgb(0, 122, 218);\"><strong>19. 𝔼𝕚𝕣𝕖𝕟𝕖 (𝔾𝕠𝕕𝕕𝕖𝕤𝕤 𝕆𝕗 ℙ𝕖𝕒𝕔𝕖)</strong></span></p><p style=\"text-align: center;\"><span style=\"color: rgb(0, 122, 218);\"><strong>20. 𝔼𝕝𝕡𝕚𝕤 (𝔾𝕠𝕕𝕕𝕖𝕤𝕤 𝕆𝕗 ℍ𝕠𝕡𝕖)</strong></span></p><p style=\"text-align: center;\"><span style=\"color: rgb(0, 122, 218);\"><strong>21. 𝔼𝕟𝕠𝕕𝕚𝕒 (𝔾𝕠𝕕𝕕𝕖𝕤𝕤 𝕆𝕗 ℝ𝕠𝕒𝕕𝕤)</strong></span></p><p style=\"text-align: center;\"><span style=\"color: rgb(0, 122, 218);\"><strong>22. 𝔼𝕠𝕤 (𝔾𝕠𝕕𝕕𝕖𝕤𝕤 𝕆𝕗 𝔻𝕒𝕨𝕟)</strong></span></p><p style=\"text-align: center;\"><span style=\"color: rgb(0, 122, 218);\"><strong>23. 𝔼𝕣𝕚𝕤 (𝔾𝕠𝕕𝕕𝕖𝕤𝕤 𝕆𝕗 𝕊𝕥𝕣𝕚𝕗𝕖)</strong></span></p><p style=\"text-align: center;\"><span style=\"color: rgb(0, 122, 218);\"><str","personality":"","scenario":"","first_message":"","avatar":"-oSxd0K0eWrIpiclDHgWo.webp","creator":"DOGGUTZ","creator_verified":false,"nsfw":true,"tags":["👩‍🦰 Female","🏰 Historical","👭 Multiple","🎲 RPG","⛪ Religion","👤 AnyPOV"],"chats":2476,"messages":59401,"created_at":"2025-06-03T01:52:43.142851+00:00"}